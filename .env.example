# App Configuration
VITE_APP_NAME=Sage SDGs AI

# Supabase (required for chat persistence)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Provider (choose one: anthropic, openai, nvidia, or leave empty for demo mode)
VITE_AI_PROVIDER=

# Anthropic/Claude API Key (recommended for best results)
VITE_ANTHROPIC_API_KEY=

# OpenAI API Key
VITE_OPENAI_API_KEY=

# NVIDIA NIM API Key
VITE_NVIDIA_API_KEY=

# Kaggle API (optional, for dataset features)
VITE_KAGGLE_USERNAME=
VITE_KAGGLE_KEY=
